# i3blocks config - Tema Nord com Nerd Fonts

[volume]
command=~/.config/i3blocks/volume.sh
interval=1
color=#88c0d0
separator=true
separator_block_width=15

[network]
command=~/.config/i3blocks/network.sh
interval=5
color=#b48ead
separator=true
separator_block_width=15

[cpu_temp]
command=~/.config/i3blocks/cpu_temp.sh
interval=10
color=#bf616a
separator=true
separator_block_width=15

[memory]
command=~/.config/i3blocks/memory.sh
interval=10
color=#a3be8c
separator=true
separator_block_width=15

[time]
command=date '+ %H:%M:%S   %d/%m/%y'
interval=1
color=#81a1c1
separator=false
